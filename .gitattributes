# Ensure consistent line endings across all platforms
* text=auto

# Python files
*.py text eol=lf
*.pyw text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows batch
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Markdown
*.md text eol=lf

# YAML
*.yaml text eol=lf
*.yml text eol=lf

# JSON
*.json text eol=lf

# Git config
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files
*.ipynb binary
*.pkl binary
*.pickle binary
*.npy binary
*.h5 binary
*.pt binary
